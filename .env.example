# Sepolia network
SEPOLIA_CHAIN_ID=11155111
SEPOLIA_RPC_URL=

# Deployment wallet
# Use a Sepolia-only key. Never commit real private keys.
PRIVATE_KEY=

# Block explorer
ETHERSCAN_API_KEY=

# Chainlink VRF v2.5 / Sepolia
VRF_COORDINATOR=
VRF_KEY_HASH=
VRF_SUBSCRIPTION_ID=
VRF_CALLBACK_GAS_LIMIT=250000
VRF_REQUEST_CONFIRMATIONS=3
VRF_NATIVE_PAYMENT=false

# Optional initial bankroll sent by the deployment script after deployment.
INITIAL_BANKROLL_WEI=0

# Frontend public configuration
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_COIN_FLIP_CASINO_ADDRESS=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
