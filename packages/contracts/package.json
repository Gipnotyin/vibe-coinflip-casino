{
  "name": "@crypto-casino/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test",
    "lint": "forge fmt --check",
    "deploy:sepolia": "forge script script/DeployCoinFlipCasino.s.sol:DeployCoinFlipCasino --rpc-url sepolia -vvvv",
    "deploy:sepolia:dry": "forge script script/DeployCoinFlipCasino.s.sol:DeployCoinFlipCasino --rpc-url sepolia -vvvv",
    "deploy:sepolia:broadcast": "forge script script/DeployCoinFlipCasino.s.sol:DeployCoinFlipCasino --rpc-url sepolia --broadcast --verify -vvvv",
    "verify:sepolia": "forge verify-contract --chain sepolia --watch --etherscan-api-key $ETHERSCAN_API_KEY",
    "export:abi": "forge build && node scripts/export-abi.mjs"
  },
  "dependencies": {
    "@chainlink/contracts": "1.5.0",
    "@openzeppelin/contracts": "5.6.1",
    "forge-std": "1.1.2"
  }
}
